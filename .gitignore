# Python
.venv/
__pycache__/
.pytest_cache/
.ruff_cache/
*.py[cod]
*.egg-info/

# JavaScript
node_modules/

# Raw survey downloads — source archive files are not versioned here
data/raw/*
!data/raw/.gitkeep

# Browser products: permit only the small public 2MRS baseline files.
# Multi-million-row tile stores and Gaia local products remain local/external assets.
data/processed/*
!data/processed/.gitkeep
!data/processed/2mrs/
!data/processed/2mrs/2mrs_lightcone.json
!data/processed/2mrs/manifest.json
!data/processed/2mpz/
!data/processed/2mpz/.gitkeep
!data/processed/wise-sc/
!data/processed/wise-sc/.gitkeep
!data/processed/desi-dr1/
!data/processed/desi-dr1/.gitkeep
!data/processed/gaia-dr3/
!data/processed/gaia-dr3/.gitkeep

