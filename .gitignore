# Python
.venv/
__pycache__/
.pytest_cache/
.ruff_cache/
*.py[cod]
*.egg-info/

# JavaScript
node_modules/

# Raw survey downloads — source archive files are not versioned here
data/raw/*
!data/raw/.gitkeep

# Browser products: permit only small public 2MRS and DESI overview files.
# Multi-million-row tile stores, Gaia local products, and research Parquet bundles
# remain local or release assets rather than ordinary Git objects.
data/processed/*
!data/processed/.gitkeep
!data/processed/2mrs/
!data/processed/2mrs/2mrs_lightcone.json
!data/processed/2mrs/manifest.json
!data/processed/2mpz/
!data/processed/2mpz/.gitkeep
!data/processed/wise-sc/
!data/processed/wise-sc/.gitkeep
!data/processed/desi-dr1/
!data/processed/desi-dr1/.gitkeep
!data/processed/desi-dr1/index.json
!data/processed/desi-dr1/overview.json
!data/processed/gaia-dr3/
!data/processed/gaia-dr3/.gitkeep

data/research/*
!data/research/.gitkeep

# OS/editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# LaTeX report build artefacts
report/*.aux
report/*.bbl
report/*.blg
report/*.fdb_latexmk
report/*.fls
report/*.log
report/*.out
report/*.toc
